{
  "title": "Kafka Operations Agent",
  "uid": "kafka-ops-overview",
  "timezone": "browser",
  "schemaVersion": 38,
  "panels": [
    {
      "title": "Consumer Group Lag (by group)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "kafka_consumer_group_lag_sum",
          "legendFormat": "{{consumergroup}} / {{topic}}"
        }
      ]
    },
    {
      "title": "Under-Replicated Partitions",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "sum(kafka_topic_partition_under_replicated_partition)",
          "legendFormat": "Under-replicated"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {"color": "green", "value": 0},
              {"color": "red", "value": 1}
            ]
          }
        }
      }
    },
    {
      "title": "Offline Partitions",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 0},
      "targets": [
        {
          "expr": "kafka_offline_partitions_count",
          "legendFormat": "Offline"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {"color": "green", "value": 0},
              {"color": "red", "value": 1}
            ]
          }
        }
      }
    },
    {
      "title": "Active Brokers",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 20, "y": 0},
      "targets": [
        {
          "expr": "count(kafka_brokers)",
          "legendFormat": "Brokers"
        }
      ]
    },
    {
      "title": "Messages Produced / sec",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [
        {
          "expr": "rate(kafka_topic_partition_current_offset[1m])",
          "legendFormat": "{{topic}} p{{partition}}"
        }
      ]
    },
    {
      "title": "Consumer Lag Heatmap (partition level)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "kafka_consumer_group_lag",
          "legendFormat": "{{consumergroup}} / {{topic}} / p{{partition}}"
        }
      ]
    }
  ]
}
